<?xml version="1.0" encoding="utf-8"?>
<!--
    QuestTrader HUD Layout
    Small persistent overlay showing active quests.
    Path: QuestTrader/gui/layouts/QuestHUD.layout
    Toggle with [Y]
-->
<html>
  <body>
    <Widget class="ScriptedWidgetEventHandler" name="root"
            x="0" y="0" width="1" height="1">

      <!-- Anchored to top-right corner -->
      <Widget class="ImageWidget" name="HUDPanel"
              x="0.77" y="0.03" width="0.22" height="0.40"
              resource="gui/textures/qt_hud_bg.edds"
              color="0 0 0 0.65" />

      <Widget class="TextWidget" name="HUDHeader"
              x="0.78" y="0.035" width="0.20" height="0.025"
              size="0.016" color="1 0.85 0.3 1"
              font="gui/fonts/DayzIcons.fnt"
              text="[ QUESTS ]" />

      <Widget class="MultilineTextWidget" name="HUDContent"
              x="0.775" y="0.062" width="0.215" height="0.33"
              size="0.014" color="0.85 0.95 0.85 1"
              text="" />

      <Widget class="TextWidget" name="HUDToggleHint"
              x="0.84" y="0.395" width="0.10" height="0.020"
              size="0.012" color="0.5 0.5 0.5 1"
              text="[Y] Toggle" />

    </Widget>
  </body>
</html>
